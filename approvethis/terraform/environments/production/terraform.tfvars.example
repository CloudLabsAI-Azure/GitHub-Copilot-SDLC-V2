# Example Terraform Variables for Production Environment
# Copy this file to terraform.tfvars and update with your values

location = "East US"

storage_account_name  = "stapprovethisprod001"
function_storage_name = "stapprovethisfnprd001"

app_service_name  = "app-approvethis-prod-001"
function_app_name = "func-approvethis-prod-001"

# ApproveThis API configuration (set via environment variables)
# approvethis_api_url = "https://app-approvethis-prod-001.azurewebsites.net"
# approvethis_api_key = "your-api-key-here"

# GitHub token for API communication (set via environment variables)
# github_token = "ghp_your_token_here"
